{
    "permissions": {
        "allow": [
            "Edit",
            "Write",
            "Read",
            "Bash(head:*)",
            "Skill(clip)",
            "Bash(obsidian help:*)",
            "Bash(where obsidian:*)",
            "Bash(cmd:*)",
            "Bash(obsidian eval:*)",
            "Bash(obsidian read:*)",
            "WebFetch(domain:*)",
            "Bash(python *)",
            "Bash(cp * *)",
            "Bash(mv * *)",
            "Bash(mkdir *)",
            // rmとrmdirのチェックはフックで行うため、ここでは許可する
            "Bash(rm *)",
            "Bash(rmdir *)"
        ],
        "deny": [
            "Bash(sudo *)",
            "Read(**/.env*)",
            "Bash(format *)"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python .claude/hooks/rm-guard.py"
                    }
                ]
            }
        ]
    }
}